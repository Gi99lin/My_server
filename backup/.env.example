# ============================================================
# Backblaze B2 credentials
# Создать bucket и Application Key в https://www.backblaze.com/
# ============================================================
B2_ACCOUNT_ID=your_keyID_here
B2_ACCOUNT_KEY=your_applicationKey_here
B2_BUCKET_NAME=my-server-backup

# ============================================================
# Restic encryption password
# ВАЖНО: сохрани этот пароль отдельно (в менеджере паролей)!
# Без него расшифровать бэкап невозможно.
# ============================================================
RESTIC_PASSWORD=generate_a_strong_password_here

# ============================================================
# Database root passwords for dumps.
# Должны совпадать с тем что задано в .env-файлах соответствующих
# сервисов (../<service>/.env). backup.sh пропускает дамп если
# контейнер или переменная отсутствуют — не падает.
# ============================================================
# Nginx Proxy Manager (MariaDB)
NPM_DB_ROOT_PASSWORD=npm_root_password

# Nextcloud (MariaDB) — обычно "mariadbroot" по умолчанию
NEXTCLOUD_DB_ROOT_PASSWORD=mariadbroot

# Marzneshin (MariaDB)
MARZNESHIN_DB_ROOT_PASSWORD=

# AI Testcase Generator (Postgres)
TESTCASE_DB_USER=postgres
TESTCASE_DB_PASSWORD=

# Guacamole (Postgres) — берётся автоматически из ../guacamole/.env,
# здесь дублировать не нужно.

# ============================================================
# Notification (optional) — Telegram bot для уведомлений
# Оставь пустым если не нужно
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
