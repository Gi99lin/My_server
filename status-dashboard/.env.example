# status-dashboard-api — REQUIRED env (copy to .env in THIS folder).
# Compose reads .env from this directory, not the repo root. If these are
# empty, status-api runs WITH NO AUTH and /stack/api leaks your topology.
#
# Both values MUST match life-dashboard/.env so one login cookie validates on
# both (shared SSO for the embedded <status-map>).
DASHBOARD_PASS=same_as_life-dashboard_.env
# openssl rand -hex 32  — identical in life-dashboard/.env and here
SESSION_SECRET=shared_session_secret_hex
