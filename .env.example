# Matrix Configuration
MATRIX_DOMAIN=your-domain.com

# Dashboards (life-dashboard + status-dashboard share one login / SSO)
# DASHBOARD_PASS — the password for dash.gigglin.tech.
# SESSION_SECRET — MUST be the same for life-dashboard-api and status-dashboard-api
#   so one login cookie validates on both. Generate: openssl rand -hex 32
DASHBOARD_PASS=your_dashboard_password_here
SESSION_SECRET=generate_with_openssl_rand_hex_32

# PostgreSQL
POSTGRES_PASSWORD=secure_password_here

# Nginx Proxy Manager (default credentials)
# Admin UI: http://your-server:81
# Default login: admin@example.com
# Default password: changeme

# Matrix Authentication Service (генерировать: openssl rand -base64 32)
MAS_ENCRYPTION_KEY=your_encryption_key_here
MAS_SIGNING_KEY=your_signing_key_here
MAS_DATABASE_KEY=your_database_key_here

# Email SMTP Configuration (для Yandex/Gmail/другого SMTP)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=your-email@yandex.ru
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=your-email@yandex.ru
SMTP_FROM_NAME=Your Site Name

# LiveKit (для Matrix RTC звонков)
# Генерировать: docker run --rm livekit/generate --api-keys
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
